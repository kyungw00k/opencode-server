{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "z-ai": {
      "name": "Z.AI",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://api.z.ai/v1",
        "apiKey": "{env:ZAI_API_KEY}"
      },
      "models": {
        "glm-4.7": {
          "name": "GLM-4.7"
        },
        "glm-4-plus": {
          "name": "GLM-4-Plus"
        },
        "glm-z1-preview": {
          "name": "GLM-Z1-Preview"
        }
      }
    }
  },
  "model": "z-ai/glm-4.7",
  "small_model": "z-ai/glm-4.7",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@0.0.68",
        "--headless",
        "--browser",
        "chromium"
      ],
      "enabled": true,
      "environment": {
        "PATH": "/home/opencode/.nvm/current/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin",
        "PLAYWRIGHT_BROWSERS_PATH": "/home/opencode/.cache/ms-playwright"
      }
    },
    "github": {
      "type": "local",
      "command": ["gh", "mcp-server"],
      "enabled": true,
      "environment": {
        "GH_TOKEN": "{env:GH_TOKEN}"
      }
    }
  },
  "plugin": [
    "oh-my-opencode",
    "opencode-agent-memory",
    "opencode-agent-skills",
    "@franlol/opencode-md-table-formatter@0.0.3",
    "opencode-worktree"
  ],
  "tools": {
    "bash": true,
    "write": true
  },
  "autoupdate": "notify"
}
